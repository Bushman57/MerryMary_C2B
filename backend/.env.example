FLASK_ENV=development
# Optional: force SQLAlchemy create_all() on startup (default true in development, false in production)
# ENABLE_DB_CREATE_ALL=true
DATABASE_URL=postgresql://user:password@host/database
MAX_UPLOAD_SIZE_MB=10
SECRET_KEY=your-secret-key-here

# Firebase Admin (verify Google Sign-In ID tokens). Use ONE of:
# 1) Path to service account JSON (Render secret files live under /etc/secrets/):
# FIREBASE_CREDENTIALS_PATH=/etc/secrets/firebase_service_account.json
# 2) Full service account JSON as a single line:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# 3) Standard Google env (local or any host with a file path):
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/serviceAccount.json
#
# Local dev without Firebase (not for production):
# FIREBASE_AUTH_DISABLED=true
#
# Optional allowlists (empty = any signed-in Firebase user):
# Prefer Firebase UIDs (Authentication → Users → User UID). If set, ONLY UIDs are checked:
# ALLOWED_FIREBASE_UIDS=AbCdEf123...,XyZ789...
# Or comma-separated emails (used only if ALLOWED_FIREBASE_UIDS is unset/empty):
# ALLOWED_EMAILS=you@gmail.com,coworker@gmail.com
